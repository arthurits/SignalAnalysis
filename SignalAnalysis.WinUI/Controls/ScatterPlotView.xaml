<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="SignalAnalysis.Controls.ScatterPlotView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SignalAnalysis.Controls"
    xmlns:winUI="using:ScottPlot.WinUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid">
        <!-- Create the WinUI plot host to be used in the code-behind -->
        <winUI:WinUIPlot x:Name="WinUIPlotHost" />
    </Grid>
    
</UserControl>
